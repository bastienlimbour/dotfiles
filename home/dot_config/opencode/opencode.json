{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "share": "manual",
  "shell": "zsh",
  "default_agent": "plan",
  "experimental": {
    "continue_loop_on_deny": true
  },
  "compaction": {
    "auto": false,
    "prune": true,
    "reserved": 20000
  },
  "instructions": ["~/.agents/rules/AGENTS.md"],
  "plugin": [],
  "tools": {
    "question": false
  },
  "permission": {
    "question": "deny",
    "skill": "ask"
  },
  "agent": {
    "plan": {
      "color": "warning",
      "options": {},
      "permission": {}
    },
    "build": {
      "color": "primary",
      "options": {},
      "permission": {}
    }
  }
}
