[
  {
    "key": "cmd+l",
    "command": "workbench.action.toggleAgentsFromKeyboard",
    "when": "!isAuxiliaryWindowFocusedContext && !isGlass",
  },
  {
    "key": "alt+cmd+j",
    "command": "-workbench.action.toggleAgentsFromKeyboard",
    "when": "!isAuxiliaryWindowFocusedContext && !isGlass",
  },
]
