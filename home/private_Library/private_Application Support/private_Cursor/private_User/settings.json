{
  // Theme
  "window.autoDetectColorScheme": true,
  "workbench.preferredDarkColorTheme": "One Dark Pro",
  "workbench.preferredLightColorTheme": "GitHub Light",
  "workbench.iconTheme": "material-icon-theme",
  "material-icon-theme.folders.theme": "specific",
  "material-icon-theme.activeIconPack": "none",
  "material-icon-theme.saturation": 0.9,

  // Typography
  "editor.fontFamily": "CommitMono Nerd Font, Menlo, Monaco, Courier New, monospace",
  "editor.fontSize": 13,
  "editor.letterSpacing": 0,
  "editor.lineHeight": 1.5,
  "terminal.integrated.fontFamily": "CommitMono Nerd Font, Menlo, Monaco, Courier New, monospace",
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.lineHeight": 1.3,

  // UI / UX
  "breadcrumbs.enabled": true,
  "breadcrumbs.icons": false,
  "breadcrumbs.symbolPath": "off",
  "editor.cursorBlinking": "phase",
  "editor.folding": true,
  "editor.hideCursorInOverviewRuler": true,
  "editor.minimap.enabled": false,
  "editor.selectionHighlight": false,
  "editor.occurrencesHighlight": "multiFile",
  "editor.roundedSelection": true,
  "editor.scrollBeyondLastLine": true,
  "editor.guides.indentation": true,
  "editor.colorDecorators": true,
  "editor.bracketPairColorization.enabled": false,
  "editor.hover.delay": 400,
  "editor.wordWrapColumn": 120,
  // "editor.padding.top": 8,
  "editor.lightbulb.enabled": "off",
  "editor.overviewRulerBorder": true,
  "editor.renderLineHighlight": "all",
  "editor.renderControlCharacters": true,
  "editor.accessibilitySupport": "off",
  // "editor.unicodeHighlight.allowedLocales": {
  //   "en": true,
  //   "fr": true,
  // },
  "workbench.tree.renderIndentGuides": "none",
  "workbench.editor.showIcons": true,
  "workbench.editor.labelFormat": "short",
  // "workbench.editor.customLabels.enabled": true,
  // "workbench.editor.customLabels.patterns": {
  //   "**/*.*": "${dirname(0)} / ${filename}.${extname}",
  // },
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.activityBar.location": "hidden",
  "workbench.tree.indent": 12,
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "explorer.openEditors.visible": 1,
  "explorer.autoReveal": false,
  "explorer.compactFolders": false,
  "window.commandCenter": true,
  "window.zoomLevel": 0,
  "diffEditor.renderSideBySide": true,
  "scm.diffDecorations": "none",
  "scm.inputFontFamily": "editor",

  // Behavior
  "editor.linkedEditing": true,
  "extensions.ignoreRecommendations": true,

  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/__pycache__": true
  },

  "telemetry.telemetryLevel": "off",

  // Security
  "task.allowAutomaticTasks": "off",
  "security.promptForLocalFileProtocolHandling": false,
  "security.workspace.trust.untrustedFiles": "open",

  // Terminal
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.shellIntegration.enabled": false,

  // Cursor
  "cursor.cpp.disabledLanguages": [],
  "cursor.composer.editorConversationDensity": "compact-ungrouped",
  "cursor.composer.usageSummaryDisplay": "always",
  "cursor.composer.shouldChimeAfterChatFinishes": true,

  // Git / Gitlens
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.decorations.enabled": false,
  "gitlens.codeLens.enabled": false,
  "gitlens.currentLine.enabled": false,
  "gitlens.views.scm.grouped.views": {
    "commits": false,
    "stashes": false
  },
  "gitlens.graph.layout": "editor",
  "gitlens.rebaseEditor.ordering": "asc",
  "git.ignoreRebaseWarning": true,

  // Performances
  "redhat.telemetry.enabled": false,
  "gitlens.telemetry.enabled": false,
  "telemetry.feedback.enabled": false,
  "editor.largeFileOptimizations": true,

  // Type checking
  // "js/ts.implicitProjectConfig.checkJs": true,

  // Linting

  // Formatting (.editorconfig)
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "editor.insertSpaces": true,
  "editor.indentSize": 2,
  "editor.tabSize": 2,

  // Formatting (built-in)
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.detectIndentation": true,
  "files.trimFinalNewlines": true,

  // Formatting (Prettier)
  "prettier.enable": false,
  "prettier.requireConfig": true,

  // Formatting (oxfmt)
  "oxc.enable.oxfmt": true,

  // Linting (extensions)
  "oxc.enable.oxlint": true,
  "oxc.trace.server": "verbose",

  // Files associations
  "emmet.includeLanguages": {
    "smarty": "html",
    "twig": "html"
  },
  "files.associations": {
    // "*.css": "tailwindcss",
    // "*.html": "smarty",
    // "*.tpl": "smarty",
    // "*.scss": "postcss",
  },
  "workbench.editorAssociations": {
    "*.svg": "default",
    "git-rebase-todo": "default"
  },

  // Suggestions
  "editor.quickSuggestions": {
    "strings": "on",
    "comments": "off",
    "other": "on"
  },

  // ----- Extensions -----

  // Project manager
  "projectManager.sortList": "Saved",

  // Tailwind CSS Intellisence
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.classFunctions": ["cva", "cn", "cs", "clsx", "twMerge"],

  // SQLTools
  "sqltools.useNodeRuntime": true,
  "sqltools.format": {
    "language": "sql",
    "linesBetweenQueries": 2
  },

  // Markdown Lint
  "markdownlint.severityForError": "Information",
  "markdownlint.severityForWarning": "Warning",
  "markdownlint.config": {
    "first-line-h1": false,
    "fenced-code-language": false
  },

  // Mermaid
  "mermaidChart.showGenerateDiagramCodeLens": false,

  // ----- Language specific -----

  // Javascript
  "javascript.suggest.autoImports": true,
  "javascript.preferences.importModuleSpecifier": "shortest",
  "javascript.preferences.importModuleSpecifierEnding": "minimal",

  // TypeScript
  "typescript.suggest.autoImports": true,
  "typescript.preferences.importModuleSpecifier": "shortest",
  "typescript.preferences.importModuleSpecifierEnding": "minimal",
  "typescript.preferences.includePackageJsonAutoImports": "auto",
  "typescript.preferences.preferTypeOnlyAutoImports": true,
  "typescript.preferences.autoImportFileExcludePatterns": ["@radix-ui/*"],

  // JSON
  "json.schemaDownload.enable": true,

  // Python
  // "python.analysis.typeCheckingMode": "basic",
  // "python.analysis.diagnosticMode": "workspace",
  // "python.analysis.autoImportCompletions": true,
  // "cursorpyright.analysis.autoImportCompletions": true,
  // "cursorpyright.analysis.diagnosticMode": "workspace",
  // "cursorpyright.analysis.typeCheckingMode": "basic"

  // ----- Languages override -----

  "[c]": {
    "editor.defaultFormatter": "anysphere.cpptools"
  },
  "[cpp]": {
    "editor.defaultFormatter": "anysphere.cpptools"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[sql]": {
    "editor.defaultFormatter": "mtxr.sqltools"
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "git.openRepositoryInParentFolders": "never",
  "editor.renderWhitespace": "none"

  // --- Unsorted ---
}
